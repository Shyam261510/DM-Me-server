generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}



model User {
  id         String      @id @default(auto()) @map("_id") @db.ObjectId
  email      String      @unique
  username   String
  reels      UserReel[]
  groups       Group[]       
  groupMembers GroupMember[]
  reciverId  String? @unique
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
}


model Group {
  id          String       @id @default(auto()) @map("_id") @db.ObjectId
  groupName    String      
  groupMembers GroupMember[]
  adminId      String      @unique @db.ObjectId
  admin        User        @relation(fields: [adminId], references: [id])
  invites      Invite[]    @relation("GroupInvites")
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model GroupMember {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  userId String  @db.ObjectId
  groupId String @db.ObjectId
  role   Role   @default(MEMBER)
  user   User   @relation(fields: [userId], references: [id])
  group   Group   @relation(fields: [groupId], references: [id])
  
  @@unique([userId, groupId])
  @@index([userId])
  @@index([groupId])
}

model Invite {
id String @id @default(auto()) @map("_id") @db.ObjectId
email String
groupId String @db.ObjectId
group Group @relation("GroupInvites",fields: [groupId], references: [id])
createdAt DateTime @default(now())

@@unique([groupId, email])
}

model Reel {
  id         String     @id @default(auto()) @map("_id") @db.ObjectId
  users      UserReel[]
  title      String
  fileName   String
  audioTranscribe String?
  niche String?
  subNiche String?
  nicheEmbeddings Float[]
  subNicheEmbeddings Float[]
  titleEmbeddings Float[]
  audioTranscribeEmbeddings Float[]
  ig_reel_id String     @unique
  createdAt  DateTime   @default(now())
}

model UserReel {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  userId String @db.ObjectId
  reelId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id])
  reel   Reel?   @relation(fields: [reelId], references: [id])
  
  @@unique([userId, reelId])
  @@index([userId])
  @@index([reelId])
}

enum Role {
  ADMIN
  MEMBER
}